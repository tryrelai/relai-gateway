# ---- Server ----
PORT=8080
# Comma-separated allowed origins for CORS (your Vercel frontend)
CORS_ORIGINS=http://localhost:3000,https://relai.xyz

# ---- Auth ----
# Long random string. Generate: openssl rand -hex 48
JWT_SECRET=change_me_to_a_long_random_string
# JWT lifetime
JWT_TTL=7d

# ---- Supabase ----
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service-role key (server only, NEVER ship to frontend)
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ---- Inference backend (OpenRouter) ----
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE=https://openrouter.ai/api/v1
# Optional attribution headers for OpenRouter
OPENROUTER_REFERER=https://relai.xyz
OPENROUTER_TITLE=Relai

# ---- Solana / chain config (public, surfaced via /api/v1/config) ----
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# $RELAI mint (placeholder until token launches)
TOKEN_MINT=          # $RELAI mint — set this to enable holder tiers/discounts
# USDC mint on mainnet
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Treasury wallet that receives USDC top-ups
TREASURY_WALLET=
TOKEN_DECIMALS=6

# ---- Top-up sweeper (auto-credits pending payments) ----
# Set SWEEPER=off to disable the background loop.
SWEEPER=on
SWEEPER_INTERVAL_MS=20000
SWEEPER_BATCH=25
